{
  "functions": [
    {
      "source": "apps/tracker",
      "codebase": "tracker",
      "ignore": [
        "node_modules",
        ".git",
        "**/*.test.ts",
        "**/*.spec.ts"
      ]
    }
  ],
  "hosting": {
    "public": "apps/dashboard/build",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "function": "tracker"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "/tracker.js",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=3600" },
          { "key": "Access-Control-Allow-Origin", "value": "*" }
        ]
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "emulators": {
    "auth": {
      "port": 9099
    },
    "functions": {
      "port": 5001
    },
    "firestore": {
      "port": 8090
    },
    "hosting": {
      "port": 5000
    },
    "ui": {
      "enabled": true,
      "port": 4000
    },
    "singleProjectMode": true
  }
}
