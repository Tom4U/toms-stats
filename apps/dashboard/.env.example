# Firebase client config — public values from Firebase Console → Project settings → Your apps
# For local dev: copy to .env.local and fill in your project's values.
# In CI/CD: set as GitHub Environment Variables under Settings → Secrets and variables
#            → Actions → Variables → Environment: production
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
