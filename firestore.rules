rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Replace OWNER_UID with your actual Firebase UID before deploying.
    // Find your UID in the Firebase Console → Authentication → Users.
    function isOwner() {
      return request.auth != null && request.auth.uid == 'OWNER_UID';
    }

    match /{document=**} {
      allow read, write: if isOwner();
    }
  }
}
