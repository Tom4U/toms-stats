rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // The owner UID below is a placeholder, substituted at deploy time from the
    // OWNER_UID GitHub secret (see .github/workflows/deploy.yml) — never commit
    // the real UID to this public repo. The placeholder is fine for this repo's
    // local flows because tracker tests and the API go through the Admin SDK /
    // Cloud Functions, which bypass rules; the Firestore emulator DOES enforce
    // these rules for direct client-SDK access. specs/04-auth.md.
    function isOwner() {
      return request.auth != null && request.auth.uid == '__OWNER_UID__';
    }

    match /{document=**} {
      allow read, write: if isOwner();
    }
  }
}
